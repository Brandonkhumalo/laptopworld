{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile",
    "buildContext": "backend",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "gunicorn config.wsgi:application -c gunicorn.conf.py"
  }
}